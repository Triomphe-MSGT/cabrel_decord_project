PORT=5000

# --- Base de données ---
# true  = fichier local server/data/db.json
# false = MongoDB Atlas (recommandé en production)
USE_JSON_DB=false

# MongoDB Atlas — Network Access : autoriser votre IP (ou 0.0.0.0/0 en dev)
# Database → Connect → Drivers → copier l'URI
MONGO_URI=mongodb+srv://<username>:<db_password>@cluster0.xxxxx.mongodb.net/cabrel-decor?retryWrites=true&w=majority

# --- Authentification admin ---
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
ADMIN_EMAIL=admin@cabreldecor.com
ADMIN_PASSWORD=motdepasse_admin_securise

# --- Cloudinary (upload images) ---
# Option A — une seule variable (Dashboard → Account Details → API environment variable)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# Option B — variables séparées
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cabrel-decor

# --- Contact ---
WHATSAPP_NUMBER=237XXXXXXXXX
CONTACT_EMAIL=contact@cabreldecor.com
FACEBOOK_PAGE_ID=cabreldecor
